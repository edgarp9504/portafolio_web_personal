---
interface Project {
  label: string;
  icon: string;
  title: string;
  problem: string;
  solution: string;
  impact: string;
  tags: string[];
  url?: string;
  featured?: boolean;
}

const projects: Project[] = [
  {
    label: 'Full-Stack · SPA · Panel Admin',
    icon: '🌿',
    title: 'Gelesha Spa — Web + Sistema de Gestión Completo',
    problem: 'Spa sin presencia digital y con gestión de citas, cobros y reportes 100% manual, lo que generaba pérdida de clientes y cero visibilidad financiera.',
    solution: 'Plataforma completa: web pública con catálogo de 50+ servicios filtrable + panel admin con dashboard de KPIs, agenda de citas, registro de cobros y reportes exportables a Excel. Todo con autenticación.',
    impact: 'Gestión 100% digital: citas, cobros y reportes desde un solo lugar',
    tags: ['React', 'JavaScript', 'Chart.js', 'LocalStorage/API', 'Vercel', 'CSS3', 'WhatsApp API'],
    url: 'https://gelesha-proyect.vercel.app/',
    featured: true,
  },
  {
    label: 'AWS · ETL',
    icon: '🛒',
    title: 'Pipeline ETL con AWS Glue para E-commerce',
    problem: 'Datos de ventas, inventario y logística en 4 sistemas distintos. Reportes tardaban 3 días en generarse manualmente.',
    solution: 'Pipeline ETL en AWS Glue con PySpark, carga en Redshift y orquestación con Step Functions.',
    impact: 'Reportes de 3 días → 15 minutos automáticos',
    tags: ['AWS Glue', 'PySpark', 'S3', 'Redshift', 'Step Functions'],
  },
  {
    label: 'Azure · Lakehouse',
    icon: '🏔️',
    title: 'Arquitectura Medallion en Azure Databricks',
    problem: 'Múltiples fuentes de datos sin gobernanza. Los analistas perdían horas buscando la "versión correcta" de los datos.',
    solution: 'Arquitectura Medallion completa (Bronze/Silver/Gold) sobre Azure Data Lake con Databricks y Delta Lake.',
    impact: '-60% tiempo de preparación de datos por analista',
    tags: ['Databricks', 'Delta Lake', 'Azure Data Factory', 'Azure Synapse'],
  },
  {
    label: 'Marketing Data · APIs',
    icon: '📣',
    title: 'Centralización de Datos de Advertising',
    problem: 'Equipo de marketing generaba reportes descargando CSVs manualmente de Google Ads, Meta y TikTok.',
    solution: 'Sistema de extracción automática vía APIs, normalización de métricas y dashboard unificado en Power BI cada 6 horas.',
    impact: '12 horas/semana de trabajo manual eliminadas',
    tags: ['Google Ads API', 'Meta API', 'TikTok API', 'Python', 'Power BI'],
  },
  {
    label: 'Turismo · Automatización',
    icon: '🌴',
    title: 'Sistema de Datos para ToursGoMX',
    problem: 'Operadora turística con reservas, pagos y operaciones en plataformas desconectadas. Sin visibilidad de rentabilidad.',
    solution: 'Integración de CRM, sistema de reservas y pasarela de pagos en un data warehouse. Dashboard de KPIs por destino y temporada.',
    impact: '+30% visibilidad de rentabilidad por operación',
    tags: ['FastAPI', 'PostgreSQL', 'AWS RDS', 'Power BI', 'Python'],
  },
  {
    label: 'IA · RAG System',
    icon: '🧠',
    title: 'Sistema RAG para Base de Conocimiento Empresarial',
    problem: 'Empresa con 5 años de documentación interna (SOPs, contratos, reportes) que nadie podía encontrar rápido.',
    solution: 'Sistema RAG con Azure OpenAI + Pinecone: los empleados hacen preguntas en lenguaje natural y obtienen respuestas con referencias.',
    impact: 'Tiempo de búsqueda: horas → menos de 30 segundos',
    tags: ['Azure OpenAI', 'LangChain', 'Pinecone', 'FastAPI', 'Python'],
  },
];
---

<section id="projects" class="bg2">
  <div class="container">
    <div class="section-label fade-up">Proyectos</div>
    <h2 class="section-title fade-up">Trabajo real, <span class="accent">resultados reales.</span></h2>
    <p class="section-sub fade-up">Casos donde la ingeniería de datos e IA generaron impacto directo en el negocio.</p>

    <div class="grid-2 stagger">
      {projects.map(p => (
        <div class={`project-card fade-up${p.featured ? ' project-card--featured' : ''}`}>
          {p.featured && (
            <div class="featured-ribbon">Proyecto destacado</div>
          )}

          <div class="project-header">
            <div>
              <div class="project-label">{p.label}</div>
              <h3>{p.title}</h3>
            </div>
            <span class="project-icon">{p.icon}</span>
          </div>

          <div class="project-section">
            <div class="project-section-label">Problema</div>
            <p>{p.problem}</p>
          </div>
          <div class="project-section">
            <div class="project-section-label">Solución</div>
            <p>{p.solution}</p>
          </div>

          <div class="impact-badge">⚡ {p.impact}</div>

          <div class="project-footer">
            <div class="tags-row">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            {p.url && (
              <a
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
                class="demo-link"
              >
                Ver demo en vivo
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .bg2 { background: var(--bg2); }
  .project-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    transition: all .3s;
  }
  .project-card:hover { border-color: rgba(0,212,255,.35); transform: translateY(-4px); box-shadow: var(--shadow); }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
  }
  .project-label {
    font-size: .72rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: .35rem;
  }
  .project-icon { font-size: 1.8rem; flex-shrink: 0; }
  .project-header h3 { margin: 0; }

  .project-section { margin-bottom: .75rem; }
  .project-section-label {
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: .3rem;
  }
  .project-section p { font-size: .88rem; color: var(--muted); margin: 0; }

  /* Featured card */
  .project-card--featured {
    border-color: rgba(0,212,255,.3);
    background: linear-gradient(135deg, #111827 0%, #0f1e30 100%);
    position: relative;
  }
  .project-card--featured:hover {
    border-color: rgba(0,212,255,.6);
    box-shadow: 0 8px 40px rgba(0,212,255,.12);
  }
  .featured-ribbon {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #000;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: .28rem .8rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  /* Footer del card (tags + link) */
  .project-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: .75rem;
    margin-top: 1rem;
  }
  .tags-row { display: flex; flex-wrap: wrap; gap: .4rem; flex: 1; }

  .demo-link {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    font-size: .82rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid rgba(0,212,255,.3);
    border-radius: 8px;
    padding: .35rem .85rem;
    transition: all .2s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .demo-link:hover {
    background: rgba(0,212,255,.08);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
</style>
