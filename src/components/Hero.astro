<section id="hero">
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>

  <div class="container hero-content">
    <div class="hero-badge">
      <span class="dot"></span> Disponible para proyectos · Cancún, México
    </div>

    <h1>
      Tus datos,<br>
      convertidos en<br>
      <span class="accent">ventaja competitiva.</span>
    </h1>

    <p class="hero-sub">
      Construyo pipelines de datos robustos, automatizo tu flujo de información
      e integro <strong>IA</strong> en tus procesos para que tomes decisiones
      basadas en evidencia — no en intuición.
    </p>

    <div class="btn-group">
      <a href="/#cta" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
