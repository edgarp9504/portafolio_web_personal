---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  pubDate?: string;
}

const {
  title = 'Edgar Pérez · Data Engineer & Cloud Consultant',
  description = 'Data Engineer y Cloud Consultant especializado en pipelines de datos, Azure, AWS, IA empresarial y automatización. Cancún, México.',
  image = '/og-default.png',
  type = 'website',
  pubDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Edgar Pérez" />

  <!-- Open Graph -->
  <meta property="og:type"        content={type} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={new URL(image, Astro.site)} />
  <meta property="og:locale"      content="es_MX" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={new URL(image, Astro.site)} />

  {pubDate && <meta property="article:published_time" content={pubDate} />}

  <!-- Sitemap & RSS -->
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="Blog · Edgar Pérez" href="/rss.xml" />

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": type === 'article' ? 'Article' : 'Person',
    "name": "Edgar Pérez",
    "jobTitle": "Data Engineer & Cloud Consultant",
    "url": Astro.site,
    "sameAs": [
      "https://linkedin.com/in/edgar-perez",
      "https://github.com/edgar-perez"
    ],
    "address": { "@type": "PostalAddress", "addressLocality": "Cancún", "addressCountry": "MX" }
  })} />
</head>
<body>
  <slot />
</body>
</html>
