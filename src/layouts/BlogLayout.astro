---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  readingTime?: number;
}

const { title, description, pubDate, tags = [], readingTime } = Astro.props;

const formatted = pubDate.toLocaleDateString('es-MX', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={`${title} · Edgar Pérez`} description={description} type="article" pubDate={pubDate.toISOString()}>

  <!-- NAV minimal -->
  <nav class="blog-nav">
    <div class="container blog-nav-inner">
      <a href="/" class="nav-logo">Edgar<span>.</span>dev</a>
      <a href="/blog" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Todos los artículos
      </a>
    </div>
  </nav>

  <main class="blog-main">
    <div class="container">
      <article>
        <!-- Header -->
        <header class="blog-header">
          {tags.length > 0 && (
            <div class="blog-tags-top">
              {tags.map(t => <span class="tag">{t}</span>)}
            </div>
          )}
          <h1 class="blog-title">{title}</h1>
          <p class="blog-subtitle">{description}</p>
          <div class="blog-meta">
            <div class="author-info">
              <div class="author-avatar-sm">EP</div>
              <div>
                <div class="author-name-sm">Edgar Pérez</div>
                <div class="author-title-sm">Data Engineer & Cloud Consultant</div>
              </div>
            </div>
            <div class="blog-meta-right">
              <span>{formatted}</span>
              {readingTime && <span>· {readingTime} min de lectura</span>}
            </div>
          </div>
        </header>

        <div class="blog-divider"></div>

        <!-- Content -->
        <div class="blog-prose">
          <slot />
        </div>

        <!-- Footer del post -->
        <div class="blog-divider"></div>
        <div class="post-footer">
          <div class="post-cta">
            <h3>¿Te resultó útil este artículo?</h3>
            <p>Si tienes un proyecto de datos o quieres automatizar tus procesos, hablemos.</p>
            <div class="btn-group">
              <a href="https://wa.me/529983253195?text=Hola%20Edgar%2C%20le%C3%AD%20tu%20art%C3%ADculo%20y%20me%20gustar%C3%ADa%20hablar" target="_blank" rel="noopener" class="btn btn-wa">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.997 1.003C6.006 1.003 1.097 5.91 1.097 11.9c0 1.91.498 3.698 1.368 5.246L1 22.997l5.98-1.442A10.853 10.853 0 0011.997 22.8c5.99 0 10.903-4.909 10.903-10.9 0-5.99-4.913-10.897-10.903-10.897zm0 19.797a8.953 8.953 0 01-4.556-1.243l-.327-.194-3.555.858.894-3.455-.213-.35A8.91 8.91 0 013.1 11.9c0-4.909 3.996-8.9 8.897-8.9 4.9 0 8.897 3.991 8.897 8.9 0 4.91-3.997 8.9-8.897 8.9z"/></svg>
                Hablar por WhatsApp
              </a>
              <a href="/#cta" class="btn btn-outline">Ver servicios</a>
            </div>
          </div>
        </div>
      </article>
    </div>
  </main>

  <!-- Floating WA -->
  <a class="wa-float" href="https://wa.me/529983253195" target="_blank" rel="noopener" aria-label="WhatsApp">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.997 1.003C6.006 1.003 1.097 5.91 1.097 11.9c0 1.91.498 3.698 1.368 5.246L1 22.997l5.98-1.442A10.853 10.853 0 0011.997 22.8c5.99 0 10.903-4.909 10.903-10.9 0-5.99-4.913-10.897-10.903-10.897zm0 19.797a8.953 8.953 0 01-4.556-1.243l-.327-.194-3.555.858.894-3.455-.213-.35A8.91 8.91 0 013.1 11.9c0-4.909 3.996-8.9 8.897-8.9 4.9 0 8.897 3.991 8.897 8.9 0 4.91-3.997 8.9-8.897 8.9z"/></svg>
  </a>
</BaseLayout>

<style>
  .blog-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10,14,26,.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }
  .blog-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo { font-weight: 700; font-size: 1.1rem; color: var(--text); text-decoration: none; }
  .nav-logo span { color: var(--accent); }
  .back-link {
    display: flex;
    align-items: center;
    gap: .5rem;
    color: var(--muted);
    text-decoration: none;
    font-size: .88rem;
    transition: color .2s;
  }
  .back-link:hover { color: var(--accent); }

  .blog-main { padding: 4rem 0 6rem; }

  .blog-header { max-width: 720px; margin-bottom: 2.5rem; }

  .blog-tags-top { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 1.25rem; }

  .blog-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .blog-subtitle { font-size: 1.1rem; color: var(--muted); margin-bottom: 1.75rem; }

  .blog-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .author-info { display: flex; align-items: center; gap: .75rem; }
  .author-avatar-sm {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: .85rem; color: #000; flex-shrink: 0;
  }
  .author-name-sm  { font-size: .9rem; font-weight: 600; }
  .author-title-sm { font-size: .78rem; color: var(--muted); }
  .blog-meta-right { font-size: .85rem; color: var(--muted); }

  .blog-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
    margin: 2.5rem 0;
  }

  .post-footer { max-width: 720px; }
  .post-cta {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .post-cta h3 { margin-bottom: .5rem; }
  .post-cta p  { color: var(--muted); margin-bottom: 1.5rem; }

  .wa-float {
    position: fixed;
    bottom: 1.75rem; right: 1.75rem;
    z-index: 999;
    width: 54px; height: 54px;
    background: linear-gradient(135deg, #25d366, #128c7e);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 20px rgba(37,211,102,.45);
    text-decoration: none;
    transition: transform .25s;
  }
  .wa-float svg { width: 26px; height: 26px; }
  .wa-float:hover { transform: scale(1.1); }
</style>
