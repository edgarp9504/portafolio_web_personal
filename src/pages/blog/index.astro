---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav    from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import WAFloat from '../../components/WAFloat.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog · Data Engineering e IA · Edgar Pérez"
  description="Artículos técnicos sobre ingeniería de datos, pipelines, Cloud (Azure/AWS), IA empresarial y automatización de marketing data."
>
  <Nav />

  <main class="blog-index">
    <div class="container">

      <div class="blog-index-header">
        <div class="section-label">Blog</div>
        <h1>Artículos sobre <span class="accent">datos e IA.</span></h1>
        <p class="section-sub">
          Casos reales, guías técnicas y lecciones aprendidas en proyectos de
          Data Engineering, Cloud y IA empresarial.
        </p>
      </div>

      <div class="posts-grid">
        {posts.map(post => {
          const formatted = post.data.pubDate.toLocaleDateString('es-MX', {
            year: 'numeric', month: 'long', day: 'numeric',
          });
          return (
            <a href={`/blog/${post.slug}`} class="post-card">
              <div class="post-card-top">
                <div class="post-tags">
                  {post.data.tags.slice(0, 3).map((t: string) => (
                    <span class="tag">{t}</span>
                  ))}
                </div>
                {post.data.featured && <span class="featured-badge">Destacado</span>}
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
              <div class="post-meta">
                <span>{formatted}</span>
                {post.data.readingTime && <span>· {post.data.readingTime} min</span>}
                <span class="post-read-more">Leer →</span>
              </div>
            </a>
          );
        })}
      </div>

      {posts.length === 0 && (
        <div class="empty-state">
          <p>Próximamente — los primeros artículos están en camino.</p>
        </div>
      )}

    </div>
  </main>

  <Footer />
  <WAFloat />
</BaseLayout>

<style>
  .blog-index { padding: 7rem 0 5rem; }
  .blog-index-header { margin-bottom: 3.5rem; }
  .blog-index-header h1 { margin-bottom: .75rem; }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .post-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    text-decoration: none;
    color: var(--text);
    display: flex;
    flex-direction: column;
    transition: all .3s;
    position: relative;
    overflow: hidden;
  }
  .post-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    transform: scaleX(0);
    transition: transform .3s;
  }
  .post-card:hover { border-color: rgba(0,212,255,.35); transform: translateY(-4px); box-shadow: var(--shadow); }
  .post-card:hover::after { transform: scaleX(1); }

  .post-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  .post-tags { display: flex; flex-wrap: wrap; gap: .4rem; }

  .featured-badge {
    background: rgba(0,212,255,.1);
    border: 1px solid rgba(0,212,255,.25);
    color: var(--accent);
    font-size: .72rem;
    padding: .2rem .6rem;
    border-radius: 100px;
    font-weight: 600;
    white-space: nowrap;
  }

  .post-title { font-size: 1.15rem; margin-bottom: .75rem; line-height: 1.3; }
  .post-excerpt { font-size: .88rem; color: var(--muted); flex: 1; margin-bottom: 1.25rem; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: .4rem;
    font-size: .8rem;
    color: var(--muted);
  }
  .post-read-more { margin-left: auto; color: var(--accent); font-weight: 600; }

  .empty-state {
    text-align: center;
    padding: 4rem;
    color: var(--muted);
  }
</style>
